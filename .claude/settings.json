{
  "model": "sonnet",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh working"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh waiting"
          },
          {
            "type": "command",
            "command": "notify-send -u critical 'Claude needs approval' 'Waiting for your permission to proceed'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh waiting"
          },
          {
            "type": "command",
            "command": "notify-send -u critical 'Claude needs your input' 'A question is waiting for your response'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh idle"
          },
          {
            "type": "command",
            "command": "notify-send 'Claude finished' 'Task completed — your attention may be needed'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "effortLevel": "medium",
  "theme": "auto"
}
